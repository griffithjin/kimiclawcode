{
  "name": "kimiclawcode-tower-of-fate",
  "version": "1.3.12",
  "description": "命运塔·首登者 - Web4.0 去中心化卡牌对战游戏",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "webpack --mode production --config webpack.client.js",
    "build:server": "webpack --mode production --config webpack.server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "cypress run",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "docker:build": "docker build -t kimiclawcode/tower-of-fate:latest .",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "deploy:staging": "./scripts/deploy-staging.sh",
    "deploy:production": "./scripts/deploy-production.sh",
    "contract:compile": "hardhat compile",
    "contract:test": "hardhat test",
    "contract:deploy:testnet": "hardhat run scripts/deploy-testnet.js --network sepolia",
    "contract:deploy:mainnet": "hardhat run scripts/deploy-mainnet.js --network mainnet",
    "db:migrate": "knex migrate:latest",
    "db:seed": "knex seed:run"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/griffithjin/kimiclawcode.git"
  },
  "keywords": [
    "tower-of-fate",
    "web4",
    "blockchain",
    "card-game",
    "multiplayer",
    "tournament",
    "nft",
    "defi"
  ],
  "author": "Kimiclaw Team <griffithjin@qq.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.3",
    "pg": "^8.11.3",
    "knex": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "ethers": "^6.9.0",
    "web3": "^4.3.0",
    "@solana/web3.js": "^1.87.6",
    "@solana/spl-token": "^0.3.9",
    "tronweb": "^5.3.0",
    "bitcoinjs-lib": "^6.1.5",
    "axios": "^1.6.2",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "crypto-js": "^4.2.0",
    "validator": "^13.11.0",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "qrcode-terminal": "^0.12.0",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.1",
    "stripe": "^14.9.0",
    "paypal-rest-sdk": "^1.8.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.2",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0",
    "cypress": "^13.6.1",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
