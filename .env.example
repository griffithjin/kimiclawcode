# ==========================================
# 命运塔·首登者 - 环境配置文件
# Tower of Fate Environment Configuration
# ==========================================

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CLIENT_URL=http://localhost:3001

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tower_of_fate
DB_USER=postgres
DB_PASSWORD=your_secure_password

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MongoDB 配置 (用于日志和统计)
MONGODB_URI=mongodb://localhost:27017/tower_of_fate

# JWT 配置
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# 区块链 API 密钥
TRON_API_KEY=your_tron_api_key
BSC_API_KEY=your_bscscan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# 加密钱包配置（仅用于监控，不是私钥）
# 这些地址已在代码中硬编码，这里用于记录
WALLET_USDT_TRC20=TUKf5QXj8nvNhsqy2va8gCnRoG77wKVwwC
WALLET_BNB_BEP20=0x6b107f2a17f218df01367f94c4a77758ba9cb4df
WALLET_ETH_ERC20=0x6b107f2a17f218df01367f94c4a77758ba9cb4df
WALLET_SOL=BYQsmcAq16BQ1K7CUphfuQJephJrDNbm3NVXtsLG6tyN
WALLET_BTC_TAPROOT=bc1pnjg9z5el0xt3uzm82symufy3lm56x82vg75dv7xm4eqvvec6j45sx9xzs0

# 游戏配置
GAME_DEFAULT_MAX_PLAYERS=4
GAME_DEFAULT_NUM_DECKS=4
GAME_TURN_TIMEOUT=30000
GAME_RAGE_PENALTY=5

# AI 配置
AI_DIFFICULTY_DEFAULT=normal
AI_THINK_TIME_MIN=1000
AI_THINK_TIME_MAX=3000

# 锦标赛配置
TOURNAMENT_MIN_PLAYERS=100
TOURNAMENT_MAX_PLAYERS=10000
TOURNAMENT_DEFAULT_ROUNDS=7

# 邮件服务 (用于通知)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@toweroffate.io
SMTP_PASS=your_smtp_password

# 第三方服务
COIN_GECKO_API_KEY=your_coingecko_api_key
IPFS_GATEWAY=https://ipfs.io/ipfs/

# 日志配置
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=7

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# 管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password
ADMIN_JWT_SECRET=admin_jwt_secret_change_this
